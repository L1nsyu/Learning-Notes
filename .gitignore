# ===============================================
# 1. 操作系统生成的垃圾文件 (必须忽略)
# ===============================================
# Mac 系统
.DS_Store
.AppleDouble
.LSOverride

# Windows 系统 (你正在用的)
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ===============================================
# 2. 编辑器/IDE 配置文件 (笔记库不需要同步这些)
# ===============================================
# IntelliJ IDEA (如果你用 IDEA 写 Markdown)
.idea/
*.iws
*.iml
*.ipr

# VS Code (如果你用 VS Code 写 Markdown)
.vscode/

# Obsidian (如果你未来用 Obsidian 管理笔记)
.obsidian/

# Typora (如果你用 Typora)
# 通常 Typora 没有特定配置文件，但为了保险
typora-debug.log

# ===============================================
# 3. 临时文件与备份 (防止 Vim 崩溃产生的 swp)
# ===============================================
*.log
*.bak
*.tmp
*.swp
*~

# ===============================================
# 4. 防御性规则：防止误传代码编译文件
# ===============================================
# 如果你偶尔在笔记文件夹里写个 Java 小 Demo，
# 我们不希望编译后的 class 文件或 target 目录被上传。
*.class
target/
*.jar
*.war

# ===============================================
# 5. 其他
# ===============================================
# 如果你有非常大的视频或压缩包不想上传，可以在这里添加
# *.zip
# *.mp4